# LLM (复用 common/llm.py)
MODEL_API_KEY=
MODEL_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# GitHub
GITHUB_TOKEN=
GITHUB_API_BASE=https://api.github.com
# Windows/Conda SSL 证书问题：先保持 true；仍失败可临时设为 false（仅开发）
HTTP_SSL_VERIFY=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_EXPIRE=86400

# Task
TASK_TIMEOUT=300
AGENT_TIMEOUT=120
MAX_CONCURRENT_TASKS=3
RATE_LIMIT_PER_MINUTE=5

# App
APP_ENV=development
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:5173
